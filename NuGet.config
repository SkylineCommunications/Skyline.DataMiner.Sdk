<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSourceMapping>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>

        <!-- Reusable Workflow -->
        <packageSource key="PrivateGitHubNuGets">
            <package pattern="Skyline.DataMiner.CICD.*" />
        </packageSource>

        <!-- MichielOD -->
        <packageSource key="GitHub">
            <package pattern="Skyline.DataMiner.CICD.*" />
        </packageSource>
    </packageSourceMapping>
</configuration>